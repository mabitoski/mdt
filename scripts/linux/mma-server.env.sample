# URL MMA cible.
export MMA_SERVER_API_URL="https://mma.marl.lan/api/ingest"

# Nom affiche dans l'interface.
export MMA_SERVER_TECHNICIAN="Infra"

# Tag facultatif.
export MMA_SERVER_TAG="Serveurs"

# Controle reseau simple.
export MMA_SERVER_PING_TARGET="1.1.1.1"
export MMA_SERVER_PING_TIMEOUT_SECONDS="2"

# Seuil NOK si un filesystem depasse ce pourcentage.
export MMA_SERVER_FS_USAGE_NOK_THRESHOLD="95"

# Timeout curl max en secondes.
export MMA_SERVER_CURL_TIMEOUT_SECONDS="20"

# Passe a 1 si tu utilises un certificat interne non reconnu localement.
export MMA_SERVER_CURL_INSECURE="0"

# Archive locale des payloads et logs si tu utilises mma-server-runner.sh.
export MMA_SERVER_RUN_DIR="/var/log/mma-server"

# Services systemd critiques a suivre.
export MMA_SERVER_SERVICE_NAMES="sshd,nginx,docker"
