<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="MMA MDT Runner"
    Manufacturer="MMA Automation"
    Version="$(var.Version)"
    UpgradeCode="A2CBF0C3-C0D4-49CA-8D80-7AEF30A34A5D"
    Scope="perMachine">

    <SummaryInformation Description="Relance des checks MDT avec file offline locale et reset optionnel." />
    <MajorUpgrade DowngradeErrorMessage="Une version plus recente de MMA MDT Runner est deja installee." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="CompanyFolder" Name="MMA Automation">
        <Directory Id="INSTALLFOLDER" Name="MdtRunner">
          <Directory Id="INSTALLSCRIPTS" Name="scripts" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="MMA MDT Runner" Level="1">
      <ComponentGroupRef Id="RunnerFiles" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="RunnerFiles">
      <Component Directory="INSTALLFOLDER" Guid="*">
        <File Source="$(var.PayloadRoot)\MmaMdtRunner.ps1" />
      </Component>
      <Component Directory="INSTALLFOLDER" Guid="*">
        <File Source="$(var.PayloadRoot)\MmaMdtRunner.Common.ps1" />
      </Component>
      <Component Directory="INSTALLFOLDER" Guid="*">
        <File Source="$(var.PayloadRoot)\config.json" />
      </Component>
      <Component Directory="INSTALLFOLDER" Guid="*">
        <File Source="$(var.PayloadRoot)\config.sample.json" />
      </Component>
      <Component Directory="INSTALLFOLDER" Guid="*">
        <File Source="$(var.PayloadRoot)\technicians.json" />
      </Component>
      <Component Directory="INSTALLFOLDER" Guid="*">
        <File Source="$(var.PayloadRoot)\Register-MmaMdtRunnerSyncTask.ps1" />
      </Component>

      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\mdt-report.ps1" />
      </Component>
      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\mdt-laptop.ps1" />
      </Component>
      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\mdt-desktop.ps1" />
      </Component>
      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\mdt-stress.ps1" />
      </Component>
      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\mdt-outbox-sync.ps1" />
      </Component>
      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\keyboard_capture.ps1" />
      </Component>
      <Component Directory="INSTALLSCRIPTS" Guid="*">
        <File Source="$(var.PayloadRoot)\scripts\camera.exe" />
      </Component>
    </ComponentGroup>

    <Component Id="DesktopShortcutComponent" Directory="DesktopFolder" Guid="*">
      <Shortcut
        Id="DesktopShortcut"
        Name="Relancer diagnostic MDT"
        WorkingDirectory="INSTALLFOLDER"
        Target="[System64Folder]WindowsPowerShell\v1.0\powershell.exe"
        Arguments="-NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]MmaMdtRunner.ps1&quot;" />
      <RegistryValue Root="HKCU" Key="Software\MMA Automation\MdtRunner" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      <RemoveFolder Id="RemoveDesktopShortcutFolder" On="uninstall" />
    </Component>
  </Fragment>
</Wix>
