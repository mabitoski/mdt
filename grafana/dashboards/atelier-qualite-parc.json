          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT DISTINCT ON (r.machine_key) r.machine_key, r.components FROM reports r WHERE COALESCE(r.machine_key,'') <> '' AND $__timeFilter(r.last_seen) ORDER BY r.machine_key, r.last_seen DESC, r.created_at DESC, r.id DESC), exploded AS (SELECT CASE e.key WHEN 'keyboard' THEN 'Clavier' WHEN 'camera' THEN 'Camera' WHEN 'usb' THEN 'USB' WHEN 'pad' THEN 'Pave tactile' WHEN 'badgeReader' THEN 'Lecteur badge' WHEN 'biosBattery' THEN 'Pile BIOS' WHEN 'biosLanguage' THEN 'Langue BIOS' WHEN 'biosPassword' THEN 'Mot de passe BIOS' WHEN 'wifiStandard' THEN 'Norme Wi-Fi' ELSE e.key END AS metric, lower(COALESCE(e.value,'')) AS status FROM latest l LEFT JOIN LATERAL jsonb_each_text(safe_jsonb(l.components)) AS e(key, value) ON TRUE) SELECT metric, COUNT(*) FILTER (WHERE status IN ('nok','timeout','denied','absent'))::integer AS value FROM exploded GROUP BY metric HAVING COUNT(*) FILTER (WHERE status IN ('nok','timeout','denied','absent')) > 0 ORDER BY value DESC LIMIT 12;",
