          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT DISTINCT ON (r.machine_key) r.machine_key, COALESCE(r.category, 'unknown') AS category, r.components FROM reports r WHERE COALESCE(r.machine_key,'') <> '' AND $__timeFilter(r.last_seen) ORDER BY r.machine_key, r.last_seen DESC, r.created_at DESC, r.id DESC), counted AS (SELECT category, l.machine_key, COUNT(*) FILTER (WHERE lower(COALESCE(e.value,'')) IN ('nok','timeout','denied','absent'))::integer AS incidents FROM latest l LEFT JOIN LATERAL jsonb_each_text(safe_jsonb(l.components)) AS e(key, value) ON TRUE GROUP BY category, l.machine_key), agg AS (SELECT CASE category WHEN 'laptop' THEN 'Portable' WHEN 'desktop' THEN 'Tour' ELSE 'Inconnu' END AS metric, COUNT(*)::integer AS postes, COUNT(*) FILTER (WHERE incidents > 0)::integer AS postes_incident FROM counted GROUP BY category) SELECT metric, ROUND(100 * COALESCE(postes_incident::numeric / NULLIF(postes, 0), 0), 1) AS value FROM agg ORDER BY value DESC;",
