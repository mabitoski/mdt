          "rawQuery": true,
          "rawSql": "WITH daily_latest AS (SELECT DISTINCT ON (r.machine_key, date_trunc('day', r.last_seen)) date_trunc('day', r.last_seen) AS day, r.machine_key, r.components FROM reports r WHERE COALESCE(r.machine_key,'') <> '' AND r.last_seen >= NOW() - INTERVAL '30 days' ORDER BY r.machine_key, date_trunc('day', r.last_seen), r.last_seen DESC, r.created_at DESC, r.id DESC) SELECT day AS \"time\", COUNT(*) FILTER (WHERE lower(COALESCE(e.value,'')) IN ('nok','timeout','denied','absent'))::integer AS incidents FROM daily_latest d LEFT JOIN LATERAL jsonb_each_text(safe_jsonb(d.components)) AS e(key, value) ON TRUE GROUP BY day ORDER BY day;",
