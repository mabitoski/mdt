      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "mdt-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT DISTINCT ON (r.machine_key) r.machine_key, COALESCE(NULLIF(r.hostname, ''), r.machine_key) AS hostname, COALESCE(NULLIF(r.serial_number, ''), '--') AS serial, COALESCE(NULLIF(r.technician, ''), '--') AS technicien, COALESCE(l.supplier || ' #' || l.lot_number, 'Sans lot') AS lot, r.last_seen, r.components FROM reports r LEFT JOIN lots l ON l.id = r.lot_id WHERE COALESCE(r.machine_key, '') <> '' ORDER BY r.machine_key, r.last_seen DESC, r.created_at DESC, r.id DESC), counted AS (SELECT l.hostname, l.serial, l.technicien, l.lot, l.last_seen, COUNT(*) FILTER (WHERE lower(COALESCE(e.value, '')) IN ('nok', 'timeout', 'denied', 'absent'))::integer AS incidents, COUNT(*) FILTER (WHERE lower(COALESCE(e.value, '')) IN ('not_tested', 'unknown', ''))::integer AS non_testes FROM latest l LEFT JOIN LATERAL jsonb_each_text(safe_jsonb(l.components)) AS e(key, value) ON TRUE GROUP BY l.hostname, l.serial, l.technicien, l.lot, l.last_seen) SELECT hostname AS \"Poste\", serial AS \"Serie\", technicien AS \"Technicien\", lot AS \"Lot\", incidents AS \"Incidents\", non_testes AS \"Non testes\", last_seen AS \"Derniere remontee\" FROM counted WHERE incidents > 0 ORDER BY incidents DESC, \"Derniere remontee\" DESC LIMIT 25;",
          "refId": "A"
        }
      ],
      "title": "Top postes a corriger",
      "type": "table"
