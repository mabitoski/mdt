          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (SELECT DISTINCT ON (r.machine_key) r.machine_key, r.components FROM reports r WHERE COALESCE(r.machine_key,'') <> '' AND $__timeFilter(r.last_seen) ORDER BY r.machine_key, r.last_seen DESC, r.created_at DESC, r.id DESC), exploded AS (SELECT CASE e.key WHEN 'diskReadTest' THEN 'Lecture disque' WHEN 'diskWriteTest' THEN 'Ecriture disque' WHEN 'ramTest' THEN 'RAM' WHEN 'cpuTest' THEN 'CPU' WHEN 'gpuTest' THEN 'GPU test' WHEN 'cpuStress' THEN 'CPU stress' WHEN 'gpuStress' THEN 'GPU stress' WHEN 'networkPing' THEN 'Ping' WHEN 'fsCheck' THEN 'Check disque' WHEN 'gpu' THEN 'GPU' WHEN 'usb' THEN 'USB' WHEN 'keyboard' THEN 'Clavier' WHEN 'camera' THEN 'Camera' WHEN 'pad' THEN 'Pave tactile' WHEN 'badgeReader' THEN 'Lecteur badge' WHEN 'biosBattery' THEN 'Pile BIOS' WHEN 'biosLanguage' THEN 'Langue BIOS' WHEN 'biosPassword' THEN 'Mot de passe BIOS' WHEN 'wifiStandard' THEN 'Norme Wi-Fi' ELSE e.key END AS metric, lower(COALESCE(e.value,'')) AS status FROM latest l LEFT JOIN LATERAL jsonb_each_text(safe_jsonb(l.components)) AS e(key, value) ON TRUE), agg AS (SELECT metric, COUNT(*) FILTER (WHERE status IN ('nok','timeout','denied','absent'))::numeric AS incident_count, COUNT(*) FILTER (WHERE status NOT IN ('not_tested','unknown',''))::numeric AS tested_count FROM exploded GROUP BY metric) SELECT metric, ROUND(100 * COALESCE(incident_count / NULLIF(tested_count, 0), 0), 1) AS value FROM agg WHERE tested_count > 0 ORDER BY value DESC;",
          "refId": "A"
        }
      ],
