          "rawSql": "SELECT supplier AS \"Fournisseur\", lot_number AS \"Lot\", target_count AS \"Objectif\", produced_count AS \"Produits\", GREATEST(target_count - produced_count, 0) AS \"Restants\", ROUND(100 * COALESCE(produced_count::numeric / NULLIF(target_count, 0), 0), 1) AS \"Progression %\", CASE WHEN is_paused THEN 'Pause' WHEN produced_count >= target_count THEN 'Termine' ELSE 'Actif' END AS \"Statut\", priority AS \"Priorite\" FROM lots ORDER BY is_paused ASC, (produced_count >= target_count) ASC, priority ASC, created_at ASC;",
