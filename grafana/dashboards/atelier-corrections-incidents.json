          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(NULLIF(r.machine_key,''), '--') AS \"Machine\", COUNT(*)::integer AS \"Regressions total\", COUNT(*) FILTER (WHERE r.regression_origin = 'manual')::integer AS \"Manuelles\", COUNT(*) FILTER (WHERE r.regression_origin = 'script')::integer AS \"Scripts\", COUNT(DISTINCT r.component_key)::integer AS \"Composants touches\", MAX(r.event_time) AS \"Derniere regression\" FROM report_component_regressions r WHERE $__timeFilter(r.event_time) GROUP BY 1 ORDER BY \"Regressions total\" DESC, \"Derniere regression\" DESC LIMIT 50;",
