          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT r.event_time AS \"Date\", COALESCE(NULLIF(r.machine_key,''), '--') AS \"Machine\", r.component_label AS \"Composant\", UPPER(COALESCE(r.previous_status_key,'--')) AS \"Avant\", UPPER(COALESCE(r.current_status_key,'--')) AS \"Apres\", CASE r.regression_origin WHEN 'manual' THEN 'Manuelle' ELSE 'Script' END AS \"Origine\", COALESCE(NULLIF(r.actor,''), '--') AS \"Acteur\", COALESCE(NULLIF(r.source_group,''), '--') AS \"Pourquoi\", COALESCE(NULLIF(r.source,''), '--') AS \"Source brute\", COALESCE(NULLIF(r.actor_ip,''), '--') AS \"IP\" FROM report_component_regressions r WHERE $__timeFilter(r.event_time) ORDER BY r.event_time DESC LIMIT 250;",
          "refId": "A"
        }
      ],
      "title": "Regressions recentes (manuel vs script)",
      "type": "table"
    },
